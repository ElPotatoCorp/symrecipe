{% extends 'base.html.twig' %}

{% block title %}
  SymRecipe - Mes recettes
{% endblock %}

{% block body %}
  <div class="container mt-4">
    {% if recipes is not empty %}
      <h1>Mes recettes</h1>

      {% for message in app.flashes('success') %}
        <div class="alert alert-dismissible alert-success mt-4">{{ message }}</div>
      {% endfor %}

      <table class="table table-striped mt-4">
        <thead>
          <tr>
            <th scope="col">Numéro</th>
            <th scope="col">Nom</th>
            <th scope="col">Temps (min)</th>
            <th scope="col">Personnes</th>
            <th scope="col">Difficulté</th>
            <th scope="col">Prix (€)</th>
            <th scope="col">Favori</th>
            <th scope="col">Ingrédients</th>
            <th scope="col">Créée le</th>
            <th scope="col">Edition</th>
            <th scope="col">Suppression</th>
          </tr>
        </thead>

        <tbody>
          {% for recipe in recipes %}
            <tr class="table-dark">
              <th scope="row">{{ recipe.id }}</th>
              <td>{{ recipe.name }}</td>
              <td>{{ recipe.time ?? '-' }}</td>
              <td>{{ recipe.nbPersons ?? '-' }}</td>
              <td>{{ recipe.difficulty ?? '-' }}</td>
              <td>{{ recipe.price ?? '-' }}</td>
              <td>
                {% if recipe.isFavorite %}
                  ⭐ Oui
                {% else %}
                  ❌ Non
                {% endif %}
              </td>
              <td>
                {% for ingredient in recipe.ingredients %}
                  <span class="badge bg-primary">{{ ingredient.name }}</span>
                {% else %}
                  <span class="text-muted">Aucun</span>
                {% endfor %}
              </td>
              <td>{{ recipe.createdAt|date('d/m/Y') }}</td>
              <td>
                <a href="#" class="btn btn-primary btn-sm">Modifier</a>
              </td>

              <td>
                <a href="#" class="btn btn-danger btn-sm" onclick="return confirm('Êtes-vous sûr de vouloir supprimer cette recette ?')">Supprimer</a>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>

      <div class="d-flex justify-content-center mt-4">{{ knp_pagination_render(recipes) }}</div>
    {% else %}
      <h4>Il n'y a aucune recette !</h4>
    {% endif %}
  </div>
{% endblock %}
