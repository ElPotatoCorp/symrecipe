{% extends 'base.html.twig' %}

{% block body %}
  <div class="container">
    <h1 class="mt-4">Édition d'une recette</h1>

    {{ form_start(form) }}

    <div class="row">
      <div class="form-error">{{ form_errors(form.name) }}</div>
      {{ form_label(form.name) }}
      {{ form_widget(form.name) }}
    </div>

    <div class="row">
      <div class="form-error">{{ form_errors(form.time) }}</div>
      {{ form_label(form.time) }}
      {{ form_widget(form.time) }}
    </div>

    <div class="row">
      <div class="form-error">{{ form_errors(form.nbPersons) }}</div>
      {{ form_label(form.nbPersons) }}
      {{ form_widget(form.nbPersons) }}
    </div>

    <div class="row">
      <div class="form-error">{{ form_errors(form.difficulty) }}</div>
      {{ form_label(form.difficulty) }}
      {{ form_widget(form.difficulty) }}
    </div>

    <div class="row">
      <div class="form-error">{{ form_errors(form.description) }}</div>
      {{ form_label(form.description) }}
      {{ form_widget(form.description) }}
    </div>

    <div class="row">
      <div class="form-error">{{ form_errors(form.price) }}</div>
      {{ form_label(form.price) }}
      {{ form_widget(form.price) }}
    </div>

    <div class="row mt-3">{{ form_label(form.isFavorite) }}
      {{ form_widget(form.isFavorite) }}</div>

    <div class="row">
      {{ form_label(form.ingredients) }}
      {% for ingredient in form.ingredients %}
        <div class="col-md-3">{{ form_widget(ingredient) }}
          {{ form_label(ingredient) }}</div>
      {% endfor %}
    </div>

    <div class="row">{{ form_row(form.submit) }}</div>

    {{ form_end(form) }}
  </div>
{% endblock %}
